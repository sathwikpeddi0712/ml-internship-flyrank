    "# ML-07 — Baseline Action Score and Top-20 Review\n",
    "\n",
    "[![\"Open In Colab\"](https://colab.research.google.com/assets/colab-badge.svg)](https://colab.research.google.com/github/DevisriprasadSoma/flyrank-ml-internship-starter/blob/main/work/notebooks/w04_baseline_score.ipynb?flush_cache=true)\n",
    "\n",
    "This notebook implements the transparent, rule-based baseline score to prioritize content refresh candidates and outputs the ranked queue to `work/outputs/baseline_action_score.csv`.\n",
    "\n",
    "---"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. My rule and its reason codes\n",
    "\n",
    "### Heuristic Rule Description\n",
    "Our baseline score prioritizes pages by combining four visual indicators:\n",
    "1. **Visibility (40%):** Higher search volume/impressions should be checked first (large absolute impact).\n",
    "2. **Freshness Risk (30%):** Older pages (days since last update) are at higher risk of decay.\n",
    "3. **Position Opportunity (25%):** Striking-distance ranks (positions 4–20) on high-volume queries offer the highest potential quick-win lift.\n",
    "4. **Depth Gap (5%):** Pages with low word counts relative to their traffic potential could be thin content candidates.\n",
    "\n",
    "### Reason Codes & Actions:\n",
    "*   `stale_visible_page` -> Action: `refresh`\n",
    "*   `declining_with_demand` -> Action: `refresh`\n",
    "*   `thin_visible_page` -> Action: `expand_and_refresh`\n",
    "*   `page_one_decay_risk` -> Action: `monitor`\n",
    "*   `low_ctr_visible_page` -> Action: `refresh_and_review_ctr`\n",
    "*   `low_engagement_visible_page` -> Action: `monitor`"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Code check: Check signal correlations and baseline logic\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "df = pd.read_csv('C:/Users/sathw/.gemini/antigravity/scratch/flyrank-ml-internship-starter/data/raw/content_refresh_anonymized.csv')\n",
    "df['is_declining'] = (df['trend_direction'] == 'down').astype(int)\n",
    "\n",
    "print(\"1. Freshness Tier decline rates (Staleness verification):\")\n",
    "print(df.groupby('freshness_tier').agg(count=('is_declining', 'count'), decline_rate=('is_declining', 'mean')))\n",
    "\n",
    "print(\"\\n2. Position Tier decline rates (Opportunity verification):\")\n",
    "print(df.groupby('position_tier').agg(count=('is_declining', 'count'), decline_rate=('is_declining', 'mean')))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Build the ranked queue (writes the CSV)\n",
    "\n",
    "We calculate the percentile ranks and apply our formula to generate `baseline_refresh_score` and write the outputs."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Fill NaNs in columns we touch\n",
    "df[\"word_count\"] = df[\"word_count\"].fillna(0)\n",
    "df[\"avg_position\"] = df[\"avg_position\"].fillna(0)\n",
    "df[\"days_since_last_update\"] = df[\"days_since_last_update\"].fillna(0)\n",
    "df[\"impressions_90d\"] = df[\"impressions_90d\"].fillna(0)\n",
    "\n",
    "def percentile_rank(series):\n",
    "    return series.rank(pct=True)\n",
    "\n",
    "def normalize(series):\n",
    "    s_min = series.min()\n",
    "    s_max = series.max()\n",
    "    if s_max - s_min == 0:\n",
    "        return series * 0\n",
    "    return (series - s_min) / (s_max - s_min)\n",
    "\n",
    "df[\"visibility_score\"] = percentile_rank(np.log1p(df[\"impressions_90d\"]))\n",
    "df[\"freshness_risk_score\"] = percentile_rank(df[\"days_since_last_update\"])\n",
    "df[\"position_opportunity_score\"] = (\n",
    "    (1 - normalize(df[\"avg_position\"].clip(lower=1, upper=50)))\n",
    "    * df[\"visibility_score\"]\n",
    "    * (df[\"avg_position\" > 0]).astype(int)\n",
    ")\n",
    "df[\"depth_gap_score\"] = (1 - percentile_rank(df[\"word_count\"])) * df[\"visibility_score\"]\n",
    "\n",
    "df[\"baseline_refresh_score\"] = (\n",
    "    0.40 * df[\"visibility_score\"]\n",
    "    + 0.30 * df[\"freshness_risk_score\"]\n",
    "    + 0.25 * df[\"position_opportunity_score\"]\n",
    "    + 0.05 * df[\"depth_gap_score\"]\n",
    ").clip(0, 1)\n",
    "\n",
    "def reason_codes(row):\n",
    "    reasons = []\n",
    "    if row[\"days_since_last_update\"] >= 180 and row[\"impressions_90d\"] >= 500:\n",
    "        reasons.append(\"stale_visible_page\")\n",
    "    if row[\"trend_direction\"] == \"down\" and row[\"impressions_90d\"] >= 100:\n",
    "        reasons.append(\"declining_with_demand\")\n",
    "    if row[\"word_count\"] > 0 and row[\"word_count\"] < 1200 and row[\"impressions_90d\"] >= 250:\n",
    "        reasons.append(\"thin_visible_page\")\n",
    "    if row[\"avg_position\"] > 0 and row[\"avg_position\"] <= 10 and row[\"content_age_days\"] >= 180:\n",
    "        reasons.append(\"page_one_decay_risk\")\n",
    "    if row[\"impressions_90d\"] >= 500 and 0 < row[\"avg_position\"] <= 20 and row[\"ctr\"] < 0.5:\n",
    "        reasons.append(\"low_ctr_visible_page\")\n",
    "    if row[\"sessions_90d\"] >= 30 and (\n",
    "        (row[\"engagement_rate\"] > 0 and row[\"engagement_rate\"] < 30)\n",
    "        or (row[\"scroll_rate\"] > 0 and row[\"scroll_rate\"].fillna(0) < 30)\n",
    "    ):\n",
    "        reasons.append(\"low_engagement_visible_page\")\n",
    "    if not reasons:\n",
    "        reasons.append(\"general_refresh_review\")\n",
    "    return \"|\".join(reasons)\n",
    "\n",
    "df[\"reason_codes\"] = df.apply(reason_codes, axis=1)\n",
    "\n",
    "def suggested_action(row):\n",
    "    reasons = set(str(row[\"reason_codes\"]).split(\"|\"))\n",
    "    if \"thin_visible_page\" in reasons:\n",
    "        return \"expand_and_refresh\"\n",
    "    if \"low_ctr_visible_page\" in reasons:\n",
    "        return \"refresh_and_review_ctr\"\n",
    "    if \"stale_visible_page\" in reasons or \"declining_with_demand\" in reasons:\n",
    "        return \"refresh\"\n",
    "    return \"monitor\"\n",
    "\n",
    "df[\"suggested_action_baseline\"] = df.apply(suggested_action, axis=1)\n",
    "df[\"baseline_rank\"] = df[\"baseline_refresh_score\"].rank(method=\"first\", ascending=False).astype(int)\n",
    "\n",
    "# Write queue to work/outputs/baseline_action_score.csv\n",
    "import os\n",
    "os.makedirs('C:/Users/sathw/.gemini/antigravity/scratch/flyrank-ml-internship-starter/work/outputs', exist_ok=True)\n",
    "output_cols = [\"content_id\", \"client_id\", \"baseline_rank\", \"baseline_refresh_score\", \"reason_codes\", \"suggested_action_baseline\", \"is_declining\"]\n",
    "df[output_cols].sort_values(\"baseline_rank\").to_csv('C:/Users/sathw/.gemini/antigravity/scratch/flyrank-ml-internship-starter/work/outputs/baseline_action_score.csv', index=False)\n",
    "print(\"Wrote baseline queue to work/outputs/baseline_action_score.csv\")"
   ]
  },
  {
